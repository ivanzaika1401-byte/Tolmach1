<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Tolmach" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#FF0C0F12</item>
        <item name="android:statusBarColor">#FF0C0F12</item>
        <item name="android:navigationBarColor">#FF0C0F12</item>
    </style>

    <style name="Theme.Tolmach.Splash" parent="Theme.SplashScreen">
